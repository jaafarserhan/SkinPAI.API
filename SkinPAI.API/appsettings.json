{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(LocalDb)\\MSSQLLocalDB;Database=SkinPAI;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "JwtSettings": {
    "SecretKey": "SkinPAI-Super-Secret-Key-For-JWT-Token-Generation-2024-Must-Be-At-Least-32-Characters",
    "Issuer": "SkinPAI.API",
    "Audience": "SkinPAI.Client",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "FileStorage": {
    "BasePath": "Uploads",
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".webp" ]
  },
  "HuggingFace": {
    "ApiKey": "YOUR_HUGGING_FACE_API_KEY_HERE",
    "InferenceApiUrl": "https://api-inference.huggingface.co/models/",
    "VisionModel": "Salesforce/blip-image-captioning-large",
    "VQAModel": "dandelin/vilt-b32-finetuned-vqa",
    "TimeoutSeconds": 60,
    "MaxRetries": 3
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "SkinPAI.API"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} | {Message:lj} | User: {UserId} | {NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/SkinPAI-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] [User:{UserId}] [Request:{RequestId}] {Message:lj}{NewLine}{Exception}",
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/SkinPAI-Errors-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90,
          "restrictedToMinimumLevel": "Error",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] [User:{UserId}] [Request:{RequestId}]{NewLine}Message: {Message:lj}{NewLine}Exception: {Exception}{NewLine}Properties: {@Properties}{NewLine}{NewLine}"
        }
      }
    ]
  },
  "LogFileSettings": {
    "BasePath": "Logs",
    "FileNamePattern": "SkinPAI-{Date:yyyyMMdd-HHmmss}",
    "RetentionDays": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
