{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug SkinPAI API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/SkinPAI.API/bin/Debug/net9.0/SkinPAI.API.dll",
            "args": ["--urls", "http://localhost:5001"],
            "cwd": "${workspaceFolder}/SkinPAI.API",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5001"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "console": "integratedTerminal",
            "logging": {
                "moduleLoad": false
            }
        },
        {
            "name": "Attach to Process",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
